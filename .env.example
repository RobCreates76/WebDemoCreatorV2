# Agent credentials can be configured in-app via Agent Settings (stored in .demo-builder/, gitignored)
# Or optionally via .env.local:

AI_PROVIDER=ollama-cloud
OLLAMA_CLOUD_URL=https://ollama.com
OLLAMA_API_KEY=
OLLAMA_MODEL=gpt-oss:120b

# Optional — enables live web research in AI Agent mode (https://exa.ai)
# Without this key, agent falls back to DuckDuckGo search results
EXA_API_KEY=
